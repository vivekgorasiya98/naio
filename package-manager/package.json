{
  "name": "niao-package-registry",
  "version": "1.0.0",
  "description": "Niao nm package registry — serves niao_libs online with admin upload and FTP sync",
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "start": "node src/server.js",
    "dev": "node --watch src/server.js",
    "seed": "node src/scripts/seed.js",
    "sync-ftp": "node src/scripts/sync-ftp.js",
    "publish-lib": "node src/scripts/publish-lib.js",
    "migrate-mongo": "node src/scripts/migrate-mongo.js",
    "check-env": "node src/scripts/check-env.js",
    "test": "node src/scripts/test-all.js",
    "test-ftp": "node src/scripts/test-ftp.js",
    "build-release": "node src/scripts/build-release.js",
    "write-manifest": "node src/scripts/write-manifest.js",
    "release": "node src/scripts/build-release.js",
    "deploy": "npm run release",
    "vercel-build": "node src/scripts/sync-public-assets.js"
  },
  "dependencies": {
    "@fastify/cors": "^10.0.2",
    "@fastify/helmet": "^13.0.1",
    "@fastify/multipart": "^9.0.3",
    "@fastify/rate-limit": "^10.2.2",
    "@fastify/static": "^8.1.1",
    "basic-ftp": "^5.0.5",
    "bcryptjs": "^2.4.3",
    "dotenv": "^16.4.7",
    "fastify": "^5.2.1",
    "jsonwebtoken": "^9.0.2",
    "mongodb": "^6.16.0",
    "tar": "^7.4.3"
  }
}
