# Niao nm Registry — copy to .env

# ── nms.taurus-tech.in (Node API + admin) ──
PORT=3000
HOST=0.0.0.0
API_URL=https://nms.taurus-tech.in
NODE_ENV=production

# ── nm.c4compare.com (static packages via StackCP FTP) ──
FILES_URL=https://nm.c4compare.com

# Admin — https://nms.taurus-tech.in/admin/
ADMIN_USERNAME=admin
ADMIN_PASSWORD=generate-a-strong-random-password
JWT_SECRET=generate-a-64-char-hex-secret
JWT_EXPIRES=8h

NIAO_VERSION=0.2.2
NIAO_GITHUB_REPO=https://github.com/vivekgorasiya98/naio

# Main NIAO website — ecosystem docs, language reference, etc.
NIAO_WEBSITE_URL=https://niao.risu.in
# NIAO_INSTAGRAM_URL=https://www.instagram.com/risusolutions/
# NIAO_LINKEDIN_URL=https://www.linkedin.com/company/risu-solutions/
# NIAO_X_URL=https://x.com/RisuSolutions
# GitHub repo link is used in footer social icons (NIAO_GITHUB_REPO above)

# MongoDB — required for multi-version registry metadata
MONGODB_URI=mongodb+srv://user:password@cluster.mongodb.net/
MONGODB_DB=niao-nms

# Optional pre-built binary URLs (shown on download page when set)
NIAO_RELEASE_WINDOWS=https://nm.c4compare.com/releases/niao-0.2.2-windows-x64.zip
# NIAO_RELEASE_LINUX=https://nm.c4compare.com/releases/niao-0.2.2-linux-x64.tar.gz
# NIAO_RELEASE_LINUX_ARM=https://nm.c4compare.com/releases/niao-0.2.2-linux-arm64.tar.gz
# NIAO_RELEASE_MACOS=https://nm.c4compare.com/releases/niao-0.2.2-macos-x64.tar.gz
# NIAO_RELEASE_MACOS_ARM=https://nm.c4compare.com/releases/niao-0.2.2-macos-arm64.tar.gz
# Build all platforms locally: NIAO_BUILD_ALL=1 (needs rustup targets + linkers)
# Or use GitHub Actions workflow: .github/workflows/niao-release.yml
# Local/VPS: ./data  |  Serverless (Vercel/Lambda): auto-uses /tmp/niao-nms/data
DATA_DIR=./data

# FTP uploads to nm.c4compare.com web root (unlock FTP in StackCP first)
FTP_HOST=ftp.stackcp.com
FTP_USER=your-account@risu.in
FTP_PASSWORD="your-ftp-password"
FTP_REMOTE_DIR=/
FTP_SECURE=false
FTP_PASSIVE=true
FTP_TIMEOUT_MS=90000
FTP_AUTO_SYNC=true
