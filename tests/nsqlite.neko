import "nsqlite"
import "io"

fn main() {
    let base = io_join(io_temp_dir(), "neko_nsqlite_test")
    io_create_dir_all(base)
    io_chdir(base)

    let db_file = io_join(base, "test.db")
    if io_exists(db_file) {
        io_remove_file(db_file)
    }

    // cwd-relative open
    let db = nsqlite.open("test.db")
    assert(type(db) == "int", "open returns handle")

    let path = nsqlite.path(db)
    assert(io_exists(path), "db file exists in cwd")

    // migrations
    nsqlite.migrate(db, [
        {version: 1, sql: "CREATE TABLE users (id INTEGER PRIMARY KEY AUTOINCREMENT, name TEXT NOT NULL, score INTEGER DEFAULT 0)"},
        {version: 2, sql: "CREATE INDEX idx_users_name ON users(name)"}
    ])

    assert(nsqlite.table_exists(db, "users"), "users table exists")
    assert(nsqlite.table_exists(db, "_nsqlite_schema_version"), "version table exists")

    let tables = nsqlite.list_tables(db)
    assert(len(tables) >= 2, "list_tables")

    let cols = nsqlite.table_info(db, "users")
    assert(len(cols) == 3, "table_info columns")
    assert(cols[0].name == "id", "first column id")

    // insert helper
    let id1 = nsqlite.insert(db, "users", {name: "Neko", score: 10})
    assert(id1 == 1, "insert rowid")

    nsqlite.exec(db, "INSERT INTO users (name, score) VALUES (?, ?)", ["Cat", 20])

    // query object format
    let rows = nsqlite.query(db, "SELECT id, name, score FROM users WHERE score >= ? ORDER BY id", [0])
    assert(len(rows) == 2, "query row count")
    assert(rows[0].name == "Neko", "query object field")
    assert(rows[1].score == 20, "query object score")

    // compact array format
    let compact = nsqlite.query(db, "SELECT id, name FROM users", [], "array")
    assert(len(compact.columns) == 2, "compact columns")
    assert(len(compact.rows) == 2, "compact rows")

    let row = nsqlite.query_row(db, "SELECT name FROM users WHERE id = ?", [1])
    assert(row.name == "Neko", "query_row")

    let val = nsqlite.query_value(db, "SELECT count(*) FROM users")
    assert(val == 2, "query_value")

    let col = nsqlite.query_column(db, "SELECT name FROM users ORDER BY id")
    assert(col[0] == "Neko", "query_column")

    // prepared statement
    let stmt = nsqlite.prepare(db, "INSERT INTO users (name, score) VALUES (?, ?)")
    nsqlite.bind(stmt, 1, "Bird")
    nsqlite.bind(stmt, 2, 5)
    nsqlite.stmt_exec(stmt)
    nsqlite.stmt_reset(stmt)
    nsqlite.finalize(stmt)

    // batch insert
    nsqlite.batch(db, "INSERT INTO users (name, score) VALUES (?, ?)", [
        ["Dog", 15],
        ["Fish", 3]
    ])

    // transaction rollback
    nsqlite.begin(db)
    nsqlite.exec(db, "UPDATE users SET score = 999 WHERE id = 1")
    nsqlite.rollback(db)
    let check = nsqlite.query_value(db, "SELECT score FROM users WHERE id = 1")
    assert(check == 10, "rollback preserved score")

    // transaction commit
    nsqlite.begin(db, "immediate")
    nsqlite.exec(db, "UPDATE users SET score = 11 WHERE id = 1")
    nsqlite.commit(db)
    check = nsqlite.query_value(db, "SELECT score FROM users WHERE id = 1")
    assert(check == 11, "commit applied")

    // async query (compact format)
    let task = nsqlite_async_query(db, "SELECT id FROM users", [], "array")
    nsqlite_task_wait(task)
    assert(nsqlite_task_done(task), "async done")
    let async_rows = nsqlite_task_result(task)
    assert(len(async_rows.rows) == 5, "async count")

    // version string
    assert(len(nsqlite.version()) > 0, "sqlite version")

    nsqlite.close(db)

    // cleanup
    io_remove_file(io_join(base, "test.db"))
    io_remove_dir(base)

    print("nsqlite tests passed")
}
