import "ncl"

let s = ncl.series(ncl.arange(1, 4), "nums")
assert(ncl.kind(s) == "ncl_series")
assert(len(ncl.series_values(s)) == 3)

let df = ncl.dataframe({
    x: ncl.arange(1, 3),
    y: ncl.mul(ncl.arange(1, 3), 3)
})
let shape = ncl.df_shape(df)
assert(shape[0] == 2)
assert(shape[1] == 2)

let col = ncl.df_get(df, "x")
assert(ncl.sum(ncl.series_values(col)) == 3)

print("ncl_series ok")
