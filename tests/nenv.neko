import "nenv"
import "io"

fn test_get_set() {
    nenv.set("NEKO_NENV_TEST", "hello")
    assert(nenv.get("NEKO_NENV_TEST") == "hello", "set/get")
    assert(nenv.has("NEKO_NENV_TEST"), "has")
    assert(nenv.get("NEKO_NENV_MISSING_XYZ", "default") == "default", "get default")
    let all = nenv.all()
    assert(all.NEKO_NENV_TEST == "hello", "all")
    nenv.unset("NEKO_NENV_TEST")
    assert(!nenv.has("NEKO_NENV_TEST"), "unset")
}

fn test_require_and_typed() {
    nenv.set("NEKO_NENV_PORT", "8080")
    nenv.set("NEKO_NENV_DEBUG", "yes")
    assert(nenv.get_int("NEKO_NENV_PORT") == 8080, "get_int")
    assert(nenv.get_bool("NEKO_NENV_DEBUG"), "get_bool")
    let req = nenv.require("NEKO_NENV_PORT")
    assert(!is_error(req), "require ok")
    let missing = nenv.require("NEKO_NENV_MISSING_ABC")
    assert(is_error(missing), "require missing")
    nenv.unset("NEKO_NENV_PORT")
    nenv.unset("NEKO_NENV_DEBUG")
}

fn test_parse_and_load() {
    let base = io_join(io_temp_dir(), "neko_nenv_test")
    io_create_dir_all(base)
    let path = io_join(base, ".env")
    io_write_file(path, "FOO=bar\n# comment\nexport BAZ=qux\nNEKO_NENV_LOAD=1\n")

    let parsed = nenv.parse(path)
    assert(!is_error(parsed), "parse")
    assert(parsed.FOO == "bar", "parse FOO")
    assert(parsed.BAZ == "qux", "parse BAZ")

    let text = nenv.parse_text("X=1\nY=two\n")
    assert(text.X == "1", "parse_text")

    let count = nenv.load(path)
    assert(!is_error(count), "load")
    assert(count >= 1, "load count")
    assert(nenv.get("NEKO_NENV_LOAD") == "1", "loaded var")

    nenv.unset("FOO")
    nenv.unset("BAZ")
    nenv.unset("NEKO_NENV_LOAD")

    io_remove_dir_all(base)
}

fn test_store() {
    let s = nenv.open()
    nenv.store_set(s, "APP_ENV", "test")
    assert(nenv.store_get(s, "APP_ENV") == "test", "store_get")
    let obj = nenv.from_object({REGION: "us-east", TIER: "dev"})
    assert(nenv.store_get(obj, "REGION") == "us-east", "from_object")
    nenv.close(s)
    nenv.close(obj)
}

fn test_validate() {
    nenv.set("NEKO_NENV_SCHEMA", "42")
    let ok = nenv.validate({required: ["NEKO_NENV_SCHEMA"], types: {NEKO_NENV_SCHEMA: "int"}})
    assert(!is_error(ok), "validate ok")
    nenv.unset("NEKO_NENV_SCHEMA")
}

fn main() {
    test_get_set()
    test_require_and_typed()
    test_parse_and_load()
    test_store()
    test_validate()
    print("nenv tests passed")
}
