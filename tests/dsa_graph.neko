import "dsa"

fn main() {
    // undirected graph BFS/DFS
    let g = graph_new(6)
    graph_add_edge(g, 0, 1)
    graph_add_edge(g, 0, 2)
    graph_add_edge(g, 1, 3)
    graph_add_edge(g, 2, 4)
    graph_add_edge(g, 3, 5)
    assert(graph_node_count(g) == 6, "node count")
    assert(graph_edge_count(g) == 5, "edge count")
    assert(len(g) == 6, "len(graph) is node count")

    let bfs = graph_bfs(g, 0)
    assert(len(bfs) == 6, "bfs visits all")
    assert(bfs[0] == 0, "bfs starts at src")
    assert(bfs[1] == 1, "bfs level 1a")
    assert(bfs[2] == 2, "bfs level 1b")

    let dfs = graph_dfs(g, 0)
    assert(len(dfs) == 6, "dfs visits all")
    assert(dfs[0] == 0, "dfs starts at src")
    assert(dfs[1] == 1, "dfs goes deep")
    assert(dfs[2] == 3, "dfs deeper")

    let nbrs = graph_neighbors(g, 0)
    assert(len(nbrs) == 2, "neighbors of 0")

    // disconnected node stays unreachable
    let g2 = graph_new(3)
    graph_add_edge(g2, 0, 1)
    let order = graph_bfs(g2, 0)
    assert(len(order) == 2, "bfs skips unreachable")

    // dijkstra shortest paths
    let w = graph_new_directed(4)
    graph_add_edge_w(w, 0, 1, 4)
    graph_add_edge_w(w, 0, 2, 1)
    graph_add_edge_w(w, 2, 1, 2)
    graph_add_edge_w(w, 1, 3, 1)
    let dist = graph_dijkstra(w, 0)
    assert(dist[0] == 0, "dist to self")
    assert(dist[1] == 3, "dist via cheaper path")
    assert(dist[2] == 1, "dist direct")
    assert(dist[3] == 4, "dist chained")

    let iso = graph_new_directed(2)
    let dist2 = graph_dijkstra(iso, 0)
    assert(dist2[1] == -1, "unreachable is -1")

    // topological sort on a DAG
    let dag = graph_new_directed(4)
    graph_add_edge(dag, 0, 1)
    graph_add_edge(dag, 0, 2)
    graph_add_edge(dag, 1, 3)
    graph_add_edge(dag, 2, 3)
    let topo = graph_topo_sort(dag)
    assert(len(topo) == 4, "topo covers all nodes")
    assert(topo[0] == 0, "topo source first")
    assert(topo[3] == 3, "topo sink last")

    // cycle -> nil
    let cyc = graph_new_directed(2)
    graph_add_edge(cyc, 0, 1)
    graph_add_edge(cyc, 1, 0)
    assert(graph_topo_sort(cyc) == nil, "cycle returns nil")

    print("dsa graph tests passed")
}
