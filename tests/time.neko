import "time" as t

fn test_wall_clock() {
    let ms = t.now_unix_ms()
    assert(ms > 0, "now_unix_ms positive")
    let s = t.now_unix_s()
    assert(s > 0, "now_unix_s positive")
    assert(len(t.now_iso()) > 10, "now_iso")
    assert(len(t.now_iso_local()) > 10, "now_iso_local")
}

fn test_format_parse() {
    let ms = t.from_parts(2026, 7, 3, 12, 30, 45, 500, "UTC")
    let text = t.format(ms, "%Y-%m-%d %H:%M:%S", "UTC")
    assert(text == "2026-07-03 12:30:45", "format UTC")
    let back = t.parse(text, "%Y-%m-%d %H:%M:%S", "UTC")
    assert(!is_error(back), "parse ok")
    assert(back == ms - 500, "parse roundtrip to second")
}

fn test_decompose() {
    let ms = t.from_parts(2026, 1, 15, 8, 0, 0, 0, "UTC")
    let d = t.decompose(ms, "UTC")
    assert(d.year == 2026, "year")
    assert(d.month == 1, "month")
    assert(d.day == 15, "day")
    assert(d.hour == 8, "hour")
    assert(d.timezone == "UTC", "timezone")
}

fn test_arithmetic() {
    let base = t.from_parts(2026, 7, 1, 0, 0, 0, 0, "UTC")
    let plus = t.add_days(base, 3)
    assert(t.diff_ms(plus, base) == 259200000, "add_days diff")
    let plus_h = t.add_hours(base, 2)
    assert(t.diff_ms(plus_h, base) == 7200000, "add_hours")
}

fn test_calendar() {
    assert(t.is_leap_year(2024), "2024 leap")
    assert(!t.is_leap_year(2023), "2023 not leap")
    assert(t.days_in_month(2024, 2) == 29, "feb 2024")
    assert(t.days_in_month(2023, 2) == 28, "feb 2023")
    assert(t.is_valid_date(2024, 2, 29), "valid leap day")
    assert(!t.is_valid_date(2023, 2, 29), "invalid leap day")
}

fn test_timezone() {
    let ms = t.from_parts(2026, 7, 3, 12, 0, 0, 0, "UTC")
    let ny = t.decompose(ms, "America/New_York")
    assert(ny.hour == 8, "NY offset in summer (EDT)")
    let offset = t.utc_offset_ms("UTC", ms)
    assert(offset == 0, "UTC offset")
}

fn test_start_end_of_day() {
    let ms = t.from_parts(2026, 7, 3, 15, 30, 0, 0, "UTC")
    let start = t.start_of_day(ms, "UTC")
    let end = t.end_of_day(ms, "UTC")
    assert(t.hour(start, "UTC") == 0, "start hour")
    assert(t.minute(start, "UTC") == 0, "start minute")
    assert(t.hour(end, "UTC") == 23, "end hour")
    assert(t.minute(end, "UTC") == 59, "end minute")
    assert(end - start == 86399999, "day span ms")
}

fn test_components() {
    let ms = t.from_parts(2026, 7, 3, 10, 45, 30, 0, "UTC")
    assert(t.year(ms, "UTC") == 2026, "year component")
    assert(t.month(ms, "UTC") == 7, "month component")
    assert(t.day(ms, "UTC") == 3, "day component")
    assert(t.weekday(ms, "UTC") == 4, "Friday = 4 (Mon=0)")
    assert(t.weekday_name(ms, "UTC") == "Friday", "weekday name")
}

fn test_sleep() {
    let before = t.now_unix_ms()
    t.sleep_ms(10)
    let after = t.now_unix_ms()
    assert(after >= before, "sleep advanced clock")
}

fn main() {
    test_wall_clock()
    test_format_parse()
    test_decompose()
    test_arithmetic()
    test_calendar()
    test_timezone()
    test_start_end_of_day()
    test_components()
    test_sleep()
    print("all time tests passed")
}
