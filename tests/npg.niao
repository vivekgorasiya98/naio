import "npg"
import "nenv"

fn main() {
    let url = nenv.get("NIAO_PG_URL")
    if url == nil || url == "" {
        print("skip: NIAO_PG_URL not set")
        return
    }

    let db = npg.connect(url)
    assert(type(db) == "int", "connect returns handle")

    npg.ping(db)
    let ver = npg.server_version(db)
    assert(len(ver) > 0, "server version")

    let tbl = "npg_test_users"

    npg.exec(db, "DROP TABLE IF EXISTS " + tbl)
    npg.migrate(db, [
        {version: 1, sql: "CREATE TABLE " + tbl + " (id SERIAL PRIMARY KEY, name TEXT NOT NULL, score INT DEFAULT 0)"},
        {version: 2, sql: "CREATE INDEX idx_" + tbl + "_name ON " + tbl + "(name)"}
    ])

    assert(npg.table_exists(db, "public", tbl), "table exists")
    assert(npg.table_exists(db, "_npg_schema_version"), "version table")

    let tables = npg.list_tables(db, "public")
    assert(len(tables) >= 2, "list_tables")

    let cols = npg.table_info(db, tbl, "public")
    assert(len(cols) == 3, "table_info columns")

    let row = npg.insert(db, tbl, {name: "Niao", score: 10})
    assert(type(row) == "object", "insert returns row")

    npg.exec(db, "INSERT INTO " + tbl + " (name, score) VALUES ($1, $2)", ["Cat", 20])

    let rows = npg.query(db, "SELECT id, name, score FROM " + tbl + " WHERE score >= $1 ORDER BY id", [0])
    assert(len(rows) == 2, "query row count")
    assert(rows[0].name == "Niao", "query object field")

    let compact = npg.query(db, "SELECT id, name FROM " + tbl, [], "array")
    assert(len(compact.columns) == 2, "array format columns")
    assert(len(compact.rows) == 2, "array format rows")

    let stmt = npg.prepare(db, "SELECT name FROM " + tbl + " WHERE id = $1")
    npg.bind(stmt, 1, rows[1].id)
    let one = npg.stmt_query(stmt)
    assert(len(one) == 1, "stmt_query")
    npg.finalize(stmt)

    npg.begin(db)
    npg.exec(db, "UPDATE " + tbl + " SET score = score + 1 WHERE id = $1", [rows[0].id])
    npg.commit(db)

    npg.batch(db, "INSERT INTO " + tbl + " (name, score) VALUES ($1, $2)", [["A", 1], ["B", 2]])

    let pool = npg.pool({url: url, max_size: 2})
    let status = npg.pool_status(pool)
    assert(status.size >= 0, "pool status")
    let conn2 = npg.pool_get(pool)
    npg.query_value(conn2, "SELECT 1")
    npg.close(conn2)
    npg.pool_close(pool)

    let task = npg_async_query(db, "SELECT count(*) FROM " + tbl)
    npg_task_wait(task)
    let count = npg_task_result(task)
    assert(type(count) == "int", "async query result")

    npg.exec(db, "DROP TABLE IF EXISTS " + tbl)
    npg.close(db)
    print("npg tests ok")
}
