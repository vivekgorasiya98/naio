// Pool/thread tests need interpreter mode: neko run --mode interp tests/parallel_pool.neko
import "parallel"

fn square(n: int) -> int {
    return n * n
}

fn main() {
    let pool = parallel_pool_new(2)
    let t1 = parallel_pool_submit(pool, square, 4)
    let t2 = parallel_pool_submit(pool, square, 7)
    assert(parallel_pool_wait(pool, t1) == 16, "pool task 1")
    assert(parallel_pool_wait(pool, t2) == 49, "pool task 2")
    parallel_pool_shutdown(pool)

    let tid = parallel_thread_spawn(square, 5)
    assert(parallel_thread_join(tid) == 25, "thread join")
}
