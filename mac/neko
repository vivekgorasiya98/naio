#!/usr/bin/env bash
# Run neko from this folder — no PATH setup required.
set -euo pipefail

MAC_DIR="$(cd "$(dirname "$0")" && pwd)"
export NEKO_HOME="$MAC_DIR/neko_home"
BIN="$NEKO_HOME/bin/neko"

if [[ ! -x "$BIN" ]]; then
    echo "Neko not built yet. In this folder run once:"
    echo "  chmod +x setup.sh neko test.sh"
    echo "  ./setup.sh"
    exit 1
fi

exec "$BIN" "$@"
