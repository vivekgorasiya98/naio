{
  "name": "niao-language",
  "displayName": "Niao Language",
  "description": "Syntax highlighting and language support for the Niao programming language (.niao files)",
  "version": "0.1.1",
  "publisher": "niao-lang",
  "license": "MIT",
  "icon": "icons/niao-file-icon.png",
  "engines": {
    "vscode": "^1.64.0"
  },
  "categories": [
    "Programming Languages"
  ],
  "keywords": [
    "niao",
    "programming language"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/niao-lang/niao"
  },
  "contributes": {
    "languages": [
      {
        "id": "niao",
        "aliases": [
          "Niao",
          "niao"
        ],
        "extensions": [
          ".niao"
        ],
        "configuration": "./language-configuration.json",
        "icon": {
          "light": "./icons/niao-file-icon.png",
          "dark": "./icons/niao-file-icon.png"
        }
      }
    ],
    "grammars": [
      {
        "language": "niao",
        "scopeName": "source.niao",
        "path": "./syntaxes/niao.tmLanguage.json"
      }
    ]
  },
  "scripts": {
    "package": "vsce package",
    "install-local": "vsce package && code --uninstall-extension niao-lang.niao-language && code --install-extension niao-language-0.1.1.vsix"
  },
  "devDependencies": {
    "@vscode/vsce": "^3.2.1"
  }
}
